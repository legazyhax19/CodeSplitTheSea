UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if not input.KeyCode or input.KeyCode == Enum.KeyCode.Unknown then return end

	if input.KeyCode == BINDS.AutoFarm then
		AUTO_FARMING = not AUTO_FARMING
		if Rayfield.Flags["AutoFarmToggle"] then
			Rayfield.Flags["AutoFarmToggle"]:Set(AUTO_FARMING)
		end
		if AUTO_FARMING then task.spawn(autoFarmLoop) end
		return
	end

	if AUTO_FARMING then return end

	if     input.KeyCode == BINDS.Collect then task.spawn(doCollect)
	elseif input.KeyCode == BINDS.Home    then doHome()
	elseif input.KeyCode == BINDS.Split   then task.spawn(doSplit)
	elseif input.KeyCode == BINDS.SellAll then doSell()
	end
end)

